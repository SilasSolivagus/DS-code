{
  "name": "@silassolivagus/deepcode",
  "version": "0.7.1",
  "description": "Claude Code-style terminal coding agent for the DeepSeek API (command: deepcode)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "deepcode": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "diff": "^5.2.2",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "marked": "^12.0.2",
    "openai": "^6.42.0",
    "react": "^18.3.1",
    "undici": "^8.4.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
